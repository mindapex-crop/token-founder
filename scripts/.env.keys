FIREWORKS_KEY=  # status: requires_browser - https://fireworks.ai
BIGMODEL_KEY=  # status: requires_browser - https://open.bigmodel.cn (phone SMS, GLM-4.7-Flash free)
AGNES_KEY=  # status: requires_browser - https://platform.agnes-ai.com (全模态免费)
NVIDIA_NIM_KEY=  # status: requires_browser - https://build.nvidia.com (NVIDIA dev account)
SAMBANOVA_KEY=  # status: requires_browser - https://sambanova.ai
