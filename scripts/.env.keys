# Token Founder API Keys - Generated 2026-06-07/08
# Format: PROVIDER_KEY=value  # status: obtained/failed/requires_browser/pending
# NOTE: All 20 providers tested require browser-based registration (OAuth/SMS/CAPTCHA)
# Only Pollinations AI works without any key

# === 立即可用（无需Key）===
POLLINATIONS_KEY=not_needed  # status: obtained - https://text.pollinations.ai/openai

# === 需要浏览器注册（按优先级）===
GOOGLE_GEMINI_KEY=  # status: requires_browser - https://aistudio.google.com/apikey (1500 RPD)
OPENROUTER_KEY=  # status: requires_browser - https://openrouter.ai/keys (27+ free models)
DEEPSEEK_KEY=  # status: requires_browser - https://platform.deepseek.com/api_keys (phone SMS, 5M tokens)
GROQ_KEY=  # status: requires_browser - https://console.groq.com/keys (30 RPM, Cloudflare WAF)
SILICONFLOW_KEY=  # status: requires_browser - https://cloud.siliconflow.cn (20M tokens)
CEREBRAS_KEY=  # status: requires_browser - https://cloud.cerebras.ai (1M TPD, Cloudflare WAF)
MISTRAL_KEY=  # status: requires_browser - https://console.mistral.ai/api-keys/ (Firebase Auth)
TOGETHER_KEY=  # status: requires_browser - https://api.together.xyz ($5 free credit)
